{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/skills/scrnaseq-pipeline/artifact-contract.schema.json",
  "title": "Single-cell ArtifactContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "format",
    "producer_stage",
    "consumer_stages",
    "statistical_unit",
    "expression_semantics",
    "path",
    "sha256",
    "validation",
    "claim_role"
  ],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]+$"},
    "artifact_type": {
      "enum": [
        "count_matrix",
        "cell_metadata",
        "feature_metadata",
        "serialized_object",
        "embedding",
        "pseudobulk_matrix",
        "model_result",
        "figure",
        "report",
        "checkpoint"
      ]
    },
    "format": {"type": "string", "minLength": 1},
    "producer_stage": {"type": "string", "pattern": "^SC[0-9]{2}_[A-Z0-9_]+$"},
    "consumer_stages": {
      "type": "array",
      "items": {"type": "string", "pattern": "^SC[0-9]{2}_[A-Z0-9_]+$"},
      "uniqueItems": true
    },
    "statistical_unit": {
      "enum": ["gene", "cell", "capture", "sample", "donor", "donor_cell_type", "interaction", "not_applicable"]
    },
    "expression_semantics": {
      "enum": [
        "raw_integer_counts",
        "ambient_corrected_counts",
        "normalized_expression",
        "scaled_expression",
        "integrated_embedding",
        "pseudobulk_raw_counts",
        "not_expression"
      ]
    },
    "feature_namespace": {"type": ["string", "null"]},
    "genome_build": {"type": ["string", "null"]},
    "units": {"type": ["string", "null"]},
    "path": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rules", "validated_at"],
      "properties": {
        "status": {"enum": ["pending", "passed", "failed"]},
        "rules": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "validated_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "claim_role": {
      "enum": ["input", "quality_control", "descriptive", "inferential", "supporting", "visualization", "audit"]
    },
    "source_artifact_ids": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
