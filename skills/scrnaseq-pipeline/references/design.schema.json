{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/skills/scrnaseq-pipeline/design.schema.json",
  "title": "Single-cell workflow design input",
  "type": "object",
  "required": ["project_id", "organism", "platform", "samples", "analysis"],
  "properties": {
    "project_id": {"type": "string", "minLength": 1},
    "organism": {"type": "string", "minLength": 1},
    "tissue": {"type": ["string", "null"]},
    "platform": {
      "enum": ["10x-3prime", "10x-5prime", "10x-feature-barcode", "10x-multiome-rna", "parse-evercode", "drop-seq", "seq-well", "smart-seq2", "generic-count-matrix", "processed-object"]
    },
    "reference_build": {"type": ["string", "null"]},
    "feature_namespace": {"type": ["string", "null"]},
    "multiplexing": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "method": {"enum": ["none", "hto", "multiseq", "genotype", "other"]},
        "demultiplexed": {"type": "boolean"}
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sample_id", "capture_id", "donor_id", "condition", "batch", "input_type", "path"],
        "properties": {
          "sample_id": {"type": "string", "minLength": 1},
          "capture_id": {"type": "string", "minLength": 1},
          "donor_id": {"type": "string", "minLength": 1},
          "condition": {"type": "string", "minLength": 1},
          "batch": {"type": "string", "minLength": 1},
          "subject_time": {"type": ["string", "number", "null"]},
          "input_type": {"enum": ["10x_mtx_dir", "10x_h5", "h5ad", "rds", "mtx", "count_matrix"]},
          "path": {"type": "string", "minLength": 1},
          "raw_droplet_path": {"type": ["string", "null"]}
        }
      }
    },
    "analysis": {
      "type": "object",
      "required": ["mode", "condition_de", "composition", "ambient_rna", "doublets", "integration"],
      "properties": {
        "mode": {"enum": ["descriptive", "inferential"]},
        "condition_de": {"type": "boolean"},
        "composition": {"type": "boolean"},
        "ambient_rna": {"enum": ["none", "soupx", "cellbender", "decontx"]},
        "doublets": {"enum": ["scdblfinder", "doubletfinder", "scrublet", "solo", "none"]},
        "normalization": {"enum": ["sctransform", "lognormalize", "scran", "scanpy-log1p"]},
        "integration": {"enum": ["none", "harmony", "seurat-rpca", "seurat-cca", "scvi", "scanorama"]},
        "trajectory": {"type": "boolean"},
        "trajectory_root": {"type": ["string", "null"]},
        "cnv": {"type": "boolean"},
        "cnv_reference": {"type": ["string", "null"]},
        "communication": {"type": "boolean"},
        "repeated_measures": {"type": "boolean"},
        "de_unit": {"enum": ["donor_pseudobulk", "sample_pseudobulk", "cell_level"]}
      }
    }
  }
}
