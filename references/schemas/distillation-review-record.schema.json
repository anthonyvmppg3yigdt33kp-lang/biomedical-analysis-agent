{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/biomedical-analysis-agent/distillation-review-record.schema.json",
  "title": "DistillationReviewRecord",
  "description": "Manual, evidence-bound review of one stable preprocessing record. Review completion is not execution verification.",
  "type": "object",
  "required": [
    "schema_version",
    "review_id",
    "batch_id",
    "batch_position",
    "queue_item_id",
    "preprocess_record_id",
    "record_title",
    "category",
    "source_evidence",
    "research_context",
    "method_sequence",
    "combination_logic",
    "package_usage",
    "code_review",
    "figure_context_review",
    "scientific_review",
    "stage_evidence",
    "decision",
    "maturity",
    "maturity_blockers",
    "reviewer",
    "review_state"
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonEmptyStrings": {
      "type": "array",
      "items": {"$ref": "#/$defs/nonEmptyString"},
      "minItems": 1
    },
    "bundleEvidence": {
      "type": "object",
      "required": [
        "bundle_id",
        "article_sha256",
        "flow_fingerprint_sha256",
        "ordered_code_count",
        "fenced_code_count",
        "ordered_code_sha256",
        "fenced_code_sha256",
        "figure_count",
        "figure_sha256"
      ],
      "properties": {
        "bundle_id": {"type": "string", "pattern": "^flow-[0-9a-f]+$"},
        "article_sha256": {
          "description": "Null only for a verified project-root/source-file bundle that has no article artifact.",
          "anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
        },
        "flow_fingerprint_sha256": {"$ref": "#/$defs/sha256"},
        "ordered_code_count": {"type": "integer", "minimum": 0},
        "fenced_code_count": {"type": "integer", "minimum": 0},
        "ordered_code_sha256": {
          "type": "array",
          "items": {"$ref": "#/$defs/sha256"}
        },
        "fenced_code_sha256": {
          "type": "array",
          "items": {"$ref": "#/$defs/sha256"}
        },
        "figure_count": {"type": "integer", "minimum": 0},
        "figure_sha256": {
          "type": "array",
          "items": {"$ref": "#/$defs/sha256"}
        }
      },
      "additionalProperties": false
    },
    "externalEvidence": {
      "type": "object",
      "required": ["target_skill", "target_relative_path", "sha256"],
      "properties": {
        "target_skill": {"$ref": "#/$defs/nonEmptyString"},
        "target_relative_path": {"$ref": "#/$defs/nonEmptyString"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "fenced_code_count": {"type": "integer", "minimum": 0},
        "image_reference_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "figureReview": {
      "type": "object",
      "required": [
        "figure_id",
        "image_sha256",
        "review_scope",
        "viewer",
        "figure_role",
        "code_binding",
        "visible",
        "interpretable",
        "confirmed",
        "cannot_assert",
        "visual_issues",
        "reproduction_class"
      ],
      "properties": {
        "figure_id": {"$ref": "#/$defs/nonEmptyString"},
        "image_sha256": {"$ref": "#/$defs/sha256"},
        "review_scope": {
          "type": "string",
          "enum": ["native_pixels", "article_context_only", "reference_only", "unresolved"]
        },
        "viewer": {
          "type": "string",
          "enum": ["codex_view_image", "article_render", "metadata_only", "not_viewed"]
        },
        "figure_role": {"$ref": "#/$defs/nonEmptyString"},
        "code_binding": {
          "type": "object",
          "required": ["status", "evidence"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["confirmed_generating_code", "inferred_nearby_code", "illustrative_only", "unresolved", "not_applicable"]
            },
            "evidence": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        },
        "visible": {"$ref": "#/$defs/nonEmptyStrings"},
        "interpretable": {"$ref": "#/$defs/nonEmptyStrings"},
        "confirmed": {"type": "array", "items": {"type": "string"}},
        "cannot_assert": {"$ref": "#/$defs/nonEmptyStrings"},
        "visual_issues": {"type": "array", "items": {"type": "string"}},
        "reproduction_class": {
          "type": "string",
          "enum": ["exact_candidate", "semantic_candidate", "style_reference", "not_reproducible", "not_assessed"]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"review_scope": {"const": "native_pixels"}}, "required": ["review_scope"]},
          "then": {"properties": {"viewer": {"const": "codex_view_image"}}}
        }
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "schema_version": {"const": "1.0"},
    "review_id": {"type": "string", "pattern": "^distill-review-record-[0-9a-f]{20}$"},
    "batch_id": {"type": "string", "pattern": "^high-value-[0-9]{3}$"},
    "batch_position": {"type": "integer", "minimum": 1},
    "queue_item_id": {"type": "string", "pattern": "^distill-review-[0-9a-f]{20}$"},
    "preprocess_record_id": {"type": "string", "pattern": "^prep-[0-9a-f]{24}$"},
    "record_title": {"$ref": "#/$defs/nonEmptyString"},
    "category": {"$ref": "#/$defs/nonEmptyString"},
    "source_evidence": {
      "type": "object",
      "required": [
        "record_sha256",
        "source_relation_sha256",
        "queue_manifest_sha256",
        "bundles",
        "external_targets",
        "source_mode"
      ],
      "properties": {
        "record_sha256": {"$ref": "#/$defs/sha256"},
        "source_relation_sha256": {"$ref": "#/$defs/sha256"},
        "queue_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "bundles": {"type": "array", "items": {"$ref": "#/$defs/bundleEvidence"}},
        "external_targets": {"type": "array", "items": {"$ref": "#/$defs/externalEvidence"}},
        "source_mode": {"const": "read_only"}
      },
      "additionalProperties": false
    },
    "research_context": {
      "type": "object",
      "required": ["research_question", "input_modality", "cohort_or_sample_structure", "descriptive_unit", "inferential_unit"],
      "properties": {
        "research_question": {"$ref": "#/$defs/nonEmptyString"},
        "input_modality": {"$ref": "#/$defs/nonEmptyString"},
        "cohort_or_sample_structure": {"$ref": "#/$defs/nonEmptyString"},
        "descriptive_unit": {"$ref": "#/$defs/nonEmptyString"},
        "inferential_unit": {"$ref": "#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "method_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order", "method", "rationale", "inputs", "outputs"],
        "properties": {
          "order": {"type": "integer", "minimum": 1},
          "method": {"$ref": "#/$defs/nonEmptyString"},
          "rationale": {"$ref": "#/$defs/nonEmptyString"},
          "inputs": {"type": "array", "items": {"type": "string"}},
          "outputs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "combination_logic": {"$ref": "#/$defs/nonEmptyString"},
    "package_usage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["package", "functions", "role", "evidence", "version_known"],
        "properties": {
          "package": {"$ref": "#/$defs/nonEmptyString"},
          "functions": {"type": "array", "items": {"type": "string"}},
          "role": {"$ref": "#/$defs/nonEmptyString"},
          "evidence": {"$ref": "#/$defs/nonEmptyString"},
          "version_known": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "code_review": {
      "type": "object",
      "required": [
        "review_scope",
        "ordered_code_items_reviewed",
        "fenced_code_items_reviewed",
        "languages",
        "syntax_evidence_ref",
        "completeness",
        "object_chain",
        "required_inputs",
        "installers_found",
        "hardcoded_paths",
        "undefined_objects",
        "gaps",
        "source_code_immutable",
        "repair_required",
        "executable_eligibility"
      ],
      "properties": {
        "review_scope": {"type": "string", "enum": ["full_inventory", "external_article_full", "no_code_available"]},
        "ordered_code_items_reviewed": {"type": "integer", "minimum": 0},
        "fenced_code_items_reviewed": {"type": "integer", "minimum": 0},
        "languages": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "syntax_evidence_ref": {"type": ["string", "null"]},
        "completeness": {"type": "string", "enum": ["complete_flow", "partial_flow", "fragments", "no_code"]},
        "object_chain": {"$ref": "#/$defs/nonEmptyString"},
        "required_inputs": {"type": "array", "items": {"type": "string"}},
        "installers_found": {"type": "array", "items": {"type": "string"}},
        "hardcoded_paths": {"type": "array", "items": {"type": "string"}},
        "undefined_objects": {"type": "array", "items": {"type": "string"}},
        "gaps": {"type": "array", "items": {"type": "string"}},
        "source_code_immutable": {"const": true},
        "repair_required": {"type": "boolean"},
        "executable_eligibility": {"type": "string", "enum": ["blocked", "parse_candidate", "fixture_candidate"]}
      },
      "additionalProperties": false
    },
    "figure_context_review": {
      "type": "object",
      "required": ["status", "figures", "unreviewed_figure_count", "selection_rationale"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["native_sample_reviewed", "context_only", "not_applicable_no_source_figure", "blocked_missing_figure", "unresolved"]
        },
        "figures": {"type": "array", "items": {"$ref": "#/$defs/figureReview"}},
        "unreviewed_figure_count": {"type": "integer", "minimum": 0},
        "selection_rationale": {"$ref": "#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "scientific_review": {
      "type": "object",
      "required": ["assumptions", "scientific_risks", "alternatives", "negative_controls", "validation_required", "claim_ceiling"],
      "properties": {
        "assumptions": {"$ref": "#/$defs/nonEmptyStrings"},
        "scientific_risks": {"$ref": "#/$defs/nonEmptyStrings"},
        "alternatives": {"$ref": "#/$defs/nonEmptyStrings"},
        "negative_controls": {"$ref": "#/$defs/nonEmptyStrings"},
        "validation_required": {"$ref": "#/$defs/nonEmptyStrings"},
        "claim_ceiling": {"$ref": "#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "stage_evidence": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["stage", "status", "evidence"],
        "properties": {
          "stage": {
            "type": "string",
            "enum": ["SOURCE_VALIDATED", "METHOD_REVIEWED", "CODE_REVIEWED", "FIGURE_CONTEXT_REVIEWED", "SCIENTIFIC_QA", "COMPLETE"]
          },
          "status": {"type": "string", "enum": ["passed", "passed_with_blockers", "blocked"]},
          "evidence": {"$ref": "#/$defs/nonEmptyString"}
        },
        "additionalProperties": false
      }
    },
    "decision": {
      "type": "object",
      "required": ["classification", "target_objects", "reason", "automatic_execution_allowed"],
      "properties": {
        "classification": {
          "type": "string",
          "enum": ["promote_candidate", "retain_variant", "method_card_only", "workflow_candidate", "blocked_evidence", "duplicate_reuse", "reject_scientific_error"]
        },
        "target_objects": {"type": "array", "items": {"type": "string"}},
        "reason": {"$ref": "#/$defs/nonEmptyString"},
        "automatic_execution_allowed": {"const": false}
      },
      "additionalProperties": false
    },
    "maturity": {"type": "string", "enum": ["raw-extracted", "normalized", "parse-verified"]},
    "maturity_blockers": {"$ref": "#/$defs/nonEmptyStrings"},
    "reviewer": {
      "type": "object",
      "required": ["reviewer_id", "reviewed_at", "tools"],
      "properties": {
        "reviewer_id": {"$ref": "#/$defs/nonEmptyString"},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "tools": {"$ref": "#/$defs/nonEmptyStrings"}
      },
      "additionalProperties": false
    },
    "review_state": {"type": "string", "enum": ["IN_PROGRESS", "COMPLETE", "STALE"]}
  },
  "additionalProperties": false
}
