{
  "schema_version": "1.0.0",
  "backend": "r",
  "r_version": "4.5.3",
  "manager": "renv",
  "task_local_only": true,
  "windows_cache_key_chars": 16,
  "r_install_strategy": "exact-windows-binary-snapshot",
  "repository_snapshot": "https://packagemanager.posit.co/cran/2026-04-23",
  "package_type": "binary",
  "windows_r_child_environment": {
    "architecture_source": "GetNativeSystemInfo",
    "native_mapping": {
      "X64": "AMD64",
      "ARM64": "ARM64",
      "X86": "x86"
    },
    "validated_architecture": "AMD64",
    "restore_if_missing": "PROCESSOR_ARCHITECTURE",
    "conflict_or_unknown": "fail",
    "scope": "child-process-only",
    "parent_environment_modified": false
  },
  "r_process_completion": {
    "shutdown_mode": "native_exit",
    "required_returncode": 0,
    "pipeline_r_warn_option": 1,
    "pipeline_warning_delivery": "immediate-stderr",
    "stdout_stderr_forbidden_patterns": [
      "warning:",
      "warning message",
      "stack imbalance",
      "iteration limit reached",
      "alternation limit reached",
      "execution halted",
      "error in ",
      "caught access violation",
      "caught segfault",
      "fatal error"
    ],
    "structured_process_evidence_required": true,
    "external_termination_helper_permitted": false
  },
  "manager_bootstrap": {
    "host_renv_required": false,
    "library_relative_to_run": "02_environment/bootstrap-library",
    "package": "renv",
