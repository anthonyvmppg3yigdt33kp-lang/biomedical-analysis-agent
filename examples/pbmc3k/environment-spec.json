  "policy": {
    "exact_seurat_required": true,
    "transitive_versions_frozen_in_renv_lock": true,
    "fallback_to_5_4_0": false,
    "installation_inside_analysis_script": false,
    "task_local_library_only": true,
    "max_identical_seurat_install_attempts": 2,
    "hard_dependencies_only": true,
    "available_version_assertion_required": true,
    "binary_archive_sha256_required": true,
    "host_renv_required": false,
    "bootstrap_library_inside_run_root": true,
    "library_description_sha256_required": true,
    "verified_environment_fast_reuse": true,
    "native_r_exit_required": true,
    "r_child_architecture_evidence_required": true,
